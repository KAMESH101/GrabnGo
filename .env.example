# ============================================
# Firebase Configuration for GrabNGo
# ============================================
# Copy this file to .env and replace with your actual Firebase credentials
# DO NOT commit .env to version control!

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# HOW TO GET THESE VALUES:
# ============================================
# 1. Go to Firebase Console: https://console.firebase.google.com
# 2. Select your project (or create new one)
# 3. Click Project Settings (gear icon)
# 4. Scroll to "Your apps" section
# 5. Click on Web app icon or create new web app
# 6. Copy the configuration values from firebaseConfig object
# 7. Replace the values above with your actual credentials

# ============================================
# IMPORTANT SECURITY NOTES:
# ============================================
# - The .env file is already in .gitignore - DO NOT commit it!
# - Keep your API keys secure
# - For production, use environment variables in your hosting platform
# - Never share these credentials publicly

# ============================================
# FIREBASE PHONE AUTHENTICATION SETUP:
# ============================================
# After adding your credentials:
# 1. Enable Phone Authentication in Firebase Console
#    - Go to Authentication → Sign-in method
#    - Enable "Phone" provider
# 2. Add test phone numbers (for development):
#    - In Phone provider settings
#    - Add test numbers like +919999999999 with code 123456
# 3. For production:
#    - Remove test phone numbers
#    - Enable billing for real SMS delivery
#    - Add authorized domains
